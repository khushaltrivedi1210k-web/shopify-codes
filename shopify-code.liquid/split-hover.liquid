<style>

/* =========================
   WINE FAVORITES SECTION
========================= */

#wine-faves-{{ section.id }}{
  width:100%;
  background:#fff;
  overflow:hidden;
  padding:70px 20px;
}

/* CONTAINER */
.wine-faves-container-{{ section.id }}{
  max-width:1600px;
  margin:0 auto;

  display:flex;
  align-items:stretch;
  gap:30px;
}

/* =========================
   LEFT CONTENT
========================= */

.wine-faves-left-{{ section.id }}{
  flex:0 0 26%;

  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:flex-start;
}

.wine-faves-title-{{ section.id }}{
  font-size:42px;
  line-height:1.2;
  font-weight:500;
  color:#111;

  margin:0 0 18px;
}

.wine-faves-desc-{{ section.id }}{
  font-size:17px;
  line-height:1.7;
  color:#666;

  margin-bottom:28px;

  max-width:320px;
}

/* BUTTON */
.wine-faves-btn-{{ section.id }}{
  display:inline-flex;
  align-items:center;
  justify-content:center;

  padding:14px 34px;

  border:1px solid #111;

  text-decoration:none;

  font-size:13px;
  letter-spacing:1px;
  text-transform:uppercase;

  color:#111;
  background:transparent;

  transition:.35s ease;
}

.wine-faves-btn-{{ section.id }}:hover{
  background:#111;
  color:#fff;
}

/* =========================
   RIGHT GALLERY
========================= */

.wine-faves-right-{{ section.id }}{
  flex:1;

  display:grid;
  grid-template-columns:repeat(3,1fr);

  gap:18px;
}

/* CARD */
.wine-fave-card-{{ section.id }}{
  position:relative;

  height:500px;

  overflow:hidden;
  border-radius:14px;

  cursor:pointer;

  background:#f3f3f3;
}

/* IMAGES */
.wine-fave-card-{{ section.id }} img{
  position:absolute;
  inset:0;

  width:100%;
  height:100%;

  object-fit:cover;

  transition:
    opacity .5s ease,
    transform .7s ease;
}

/* NORMAL */
.wine-img-normal-{{ section.id }}{
  opacity:1;
  z-index:2;
}

/* HOVER */
.wine-img-hover-{{ section.id }}{
  opacity:0;
  z-index:1;
}

/* HOVER EFFECT */
.wine-fave-card-{{ section.id }}:hover .wine-img-normal-{{ section.id }}{
  opacity:0;
}

.wine-fave-card-{{ section.id }}:hover .wine-img-hover-{{ section.id }}{
  opacity:1;
}

.wine-fave-card-{{ section.id }}:hover img{
  transform:scale(1.06);
}

/* OVERLAY */
.wine-overlay-{{ section.id }},
.wine-overlay-hover-{{ section.id }}{
  position:absolute;

  top:50%;
  left:50%;

  transform:translate(-50%,-50%);

  z-index:5;

  color:#fff;

  font-size:34px;
  font-weight:500;

  text-align:center;

  text-shadow:
    0 3px 18px rgba(0,0,0,.45);

  transition:.45s ease;
}

/* HOVER TEXT */
.wine-overlay-hover-{{ section.id }}{
  opacity:0;
  visibility:hidden;

  transform:translate(-50%,-35%);
}

/* HOVER ANIMATION */
.wine-fave-card-{{ section.id }}:hover .wine-overlay-{{ section.id }}{
  opacity:0;
  visibility:hidden;

  transform:translate(-50%,-70%);
}

.wine-fave-card-{{ section.id }}:hover .wine-overlay-hover-{{ section.id }}{
  opacity:1;
  visibility:visible;

  transform:translate(-50%,-50%);
}

/* =========================
   TABLET
========================= */

@media(max-width:1100px){

  .wine-faves-container-{{ section.id }}{
    flex-direction:column;
  }

  .wine-faves-left-{{ section.id }}{
    text-align:center;
    align-items:center;
  }

  .wine-faves-desc-{{ section.id }}{
    max-width:700px;
  }

  .wine-faves-right-{{ section.id }}{
    grid-template-columns:repeat(3,1fr);
  }

  .wine-fave-card-{{ section.id }}{
    height:420px;
  }

}

/* =========================
   MOBILE
========================= */

@media(max-width:767px){

  #wine-faves-{{ section.id }}{
    padding:50px 15px;
  }

  .wine-faves-title-{{ section.id }}{
    font-size:30px;
  }

  .wine-faves-desc-{{ section.id }}{
    font-size:15px;
  }

  .wine-faves-right-{{ section.id }}{
    grid-template-columns:1fr;
    gap:15px;
  }

  .wine-fave-card-{{ section.id }}{
    height:380px;
  }

  .wine-overlay-{{ section.id }},
  .wine-overlay-hover-{{ section.id }}{
    font-size:28px;
  }

}

</style>


<section id="wine-faves-{{ section.id }}">

  <div class="wine-faves-container-{{ section.id }}">


    <!-- =========================
         LEFT CONTENT
    ========================== -->

    <div class="wine-faves-left-{{ section.id }}">

      {% if section.settings.title != blank %}
        <h2 class="wine-faves-title-{{ section.id }}">
          {{ section.settings.title }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="wine-faves-desc-{{ section.id }}">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="wine-faves-btn-{{ section.id }}"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>



    <!-- =========================
         GALLERY
    ========================== -->

    <div class="wine-faves-right-{{ section.id }}">


      {% for block in section.blocks %}

        <div
          class="wine-fave-card-{{ section.id }}"
          {{ block.shopify_attributes }}
        >

          <!-- NORMAL IMAGE -->
          {% if block.settings.image_normal != blank %}

            <img
              class="wine-img-normal-{{ section.id }}"
              src="{{ block.settings.image_normal | image_url: width: 1200 }}"
              alt="{{ block.settings.overlay_text }}"
              loading="lazy"
            >

          {% endif %}


          <!-- HOVER IMAGE -->
          {% if block.settings.image_hover != blank %}

            <img
              class="wine-img-hover-{{ section.id }}"
              src="{{ block.settings.image_hover | image_url: width: 1200 }}"
              alt="{{ block.settings.overlay_texthover }}"
              loading="lazy"
            >

          {% endif %}


          <!-- NORMAL TEXT -->
          <div class="wine-overlay-{{ section.id }}">
            {{ block.settings.overlay_text }}
          </div>


          <!-- HOVER TEXT -->
          <div class="wine-overlay-hover-{{ section.id }}">
            {{ block.settings.overlay_texthover }}
          </div>

        </div>

      {% endfor %}


    </div>

  </div>

</section>



{% schema %}
{
  "name": "Wine Hover Gallery",

  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Top Faves"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Write something useful to describe this section."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "gallery_item",
      "name": "Gallery Item",
      "limit": 3,

      "settings": [
        {
          "type": "image_picker",
          "id": "image_normal",
          "label": "Normal Image"
        },
        {
          "type": "image_picker",
          "id": "image_hover",
          "label": "Hover Image"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Overlay Text",
          "default": "Rare"
        },
        {
          "type": "text",
          "id": "overlay_texthover",
          "label": "Overlay Hover Text",
          "default": "Bold"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Wine Hover Gallery"
    }
  ]
}
{% endschema %}