{%- style -%}
.lb-section-{{ section.id }}{
  width:100%;
  overflow:hidden;
  background:#fdfdfd;
  padding:70px 0;
}

.lb-container{
  width:100%;
  max-width:1600px;
  margin:0 auto;

}


.lb-header{
  text-align:center;
  margin-bottom:40px;
}

.lb-header p{
  margin:0 0 8px;
  font-size:11px;
  letter-spacing:2px;
  text-transform:uppercase;
  color:#d9c24b;
}

.lb-header h2{
  margin:0;
  font-size:34px;
  font-weight:500;
  color:#111;
}

.lb-viewport{
  width:100%;
  overflow:hidden;
  position:relative;
  padding:80px 0;
}

.lb-track{
  display:flex;
  align-items:center;
  will-change:transform;
  transition:transform .6s cubic-bezier(.25,1,.3,1);
}

.lb-slide{
  flex:0 0 20%;
  padding:0 12px;
  box-sizing:border-box;

  opacity:.35;
  transform:scale(.82);

  transition:
    transform .6s ease,
    opacity .6s ease;

  position:relative;
  z-index:1;
}

.lb-slide.is-active{
  opacity:1 !important;
  transform:scale(1.12) !important;
  z-index:20;
}

.lb-media-wrap{
  width:100%;
  height:400px;
  overflow:hidden;
  border-radius:14px;
  background:#eee;

  box-shadow:
    0 10px 35px rgba(0,0,0,.08);
}

.lb-media-wrap img,
.lb-media-wrap video{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.lb-info{
  display:flex;
  align-items:center;
  gap:12px;

  padding:18px 5px 0;

  opacity:0;
  visibility:hidden;

  transition:.4s ease;
}

.lb-slide.is-active .lb-info{
  opacity:1;
  visibility:visible;
}

.lb-p-thumb{
  width:50px;
  height:50px;
  border-radius:6px;
  object-fit:cover;
  border:1px solid #eee;
}

.lb-p-text p{
  margin:0;
  font-size:14px;
  font-weight:600;
  color:#222;
}

.lb-p-text span{
  font-size:13px;
  color:#777;
}

.lb-arrow{
  position:absolute;
  top:50%;
  transform:translateY(-50%);

  width:48px;
  height:48px;

  border:none;
  border-radius:50%;

  background:#000;
  cursor:pointer;

  display:flex;
  align-items:center;
  justify-content:center;

  z-index:50;

  transition:.3s ease;
}

.lb-arrow:hover{
  background:#222;
}

.lb-arrow svg{
  width:22px;
  height:22px;
  fill:#fff;
}

.lb-prev{
  left:18px;
}

.lb-next{
  right:18px;
}


@media(max-width:1200px){

  .lb-slide{
    flex:0 0 25%;
  }

}

@media(max-width:991px){

  .lb-slide{
    flex:0 0 33.33%;
  }

  .lb-slide.is-active{
    transform:scale(1.08) !important;
  }

  .lb-media-wrap{
    height:430px;
  }

  .lb-header h2{
    font-size:30px;
  }

}


@media(max-width:767px){

  .lb-section-{{ section.id }}{
    padding:50px 0;
  }

  .lb-slide{
    flex:0 0 80%;
    padding:0 8px;
  }

  .lb-slide.is-active{
    transform:scale(1.03) !important;
  }

  .lb-media-wrap{
    height:340px;
  }

  .lb-header h2{
    font-size:24px;
  }

  .lb-arrow{
    width:40px;
    height:40px;
  }

  .lb-prev{
    left:8px;
  }

  .lb-next{
    right:8px;
  }

}

{%- endstyle -%}


<div class="lb-section-{{ section.id }}">

  <div class="lb-container">

    <div class="lb-header">

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}

      <h2>{{ section.settings.heading }}</h2>

    </div>

    <div class="lb-viewport" id="vp-{{ section.id }}">

      <button class="lb-arrow lb-prev" id="prev-{{ section.id }}">

        <svg viewBox="0 0 24 24">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>

      </button>

      <div class="lb-track" id="tr-{{ section.id }}">

        {% for block in section.blocks %}

          <div class="lb-slide" {{ block.shopify_attributes }}>

            <div class="lb-media-wrap">

              {% if block.settings.video_url != blank %}

                {{
                  block.settings.video_url
                  | video_tag:
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  playsinline: true
                }}

              {% elsif block.settings.main_image != blank %}

                <imgsrc="{{ block.settings.main_image | image_url: width: 1400 }}"
                  alt="{{ block.settings.product_title }}"loading="lazy">

              {% endif %}

            </div>

            <div class="lb-info">

              {% if block.settings.product_image != blank %}

                <imgclass="lb-p-thumb"src="{{ block.settings.product_image | image_url: width: 150 }}"alt="{{ block.settings.product_title }}">

              {% endif %}

              <div class="lb-p-text">

                <p>{{ block.settings.product_title }}</p>

                <span>{{ block.settings.product_price }}</span>

              </div>

            </div>

          </div>

        {% endfor %}

      </div>

      <button class="lb-arrow lb-next" id="next-{{ section.id }}">

        <svg viewBox="0 0 24 24">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>

      </button>

    </div>

  </div>

</div>


<script>
document.addEventListener('DOMContentLoaded', function () {

  const track = document.getElementById('tr-{{ section.id }}');
  const viewport = document.getElementById('vp-{{ section.id }}');

  const nextBtn = document.getElementById('next-{{ section.id }}');
  const prevBtn = document.getElementById('prev-{{ section.id }}');

  const originalSlides = Array.from(track.children);

  const count = originalSlides.length;

  if (!count) return;

  originalSlides.forEach(slide => {
    track.appendChild(slide.cloneNode(true));
  });

  originalSlides.slice().reverse().forEach(slide => {
    track.insertBefore(slide.cloneNode(true), track.firstChild);
  });

  let slides = Array.from(track.children);

  let current = count;

  function updateSlider(animation = true) {

    const slideWidth = slides[0].offsetWidth;

    /* PERFECT CENTER */
    const centerOffset =
      (viewport.offsetWidth / 2) - (slideWidth / 2);

    const moveX =
      -(current * slideWidth) + centerOffset;

    track.style.transition = animation
      ? 'transform .6s cubic-bezier(.25,1,.3,1)'
      : 'none';

    track.style.transform =
      `translateX(${moveX}px)`;

    slides.forEach((slide, index) => {

      slide.classList.remove('is-active');

      const video = slide.querySelector('video');

      if(video){
        video.pause();
      }

      if(index === current){

        slide.classList.add('is-active');

        if(video){
          video.play().catch(()=>{});
        }

      }

    });

  }

  nextBtn.addEventListener('click', () => {

    current++;

    updateSlider(true);

    setTimeout(() => {

      if(current >= slides.length - count){

        current = count;

        updateSlider(false);

      }

    }, 650);

  });

  prevBtn.addEventListener('click', () => {

    current--;

    updateSlider(true);

    setTimeout(() => {

      if(current < count){

        current = slides.length - (count * 2);

        updateSlider(false);

      }

    }, 650);

  });

  window.addEventListener('resize', () => {

    updateSlider(false);

  });

  /* INIT */
  setTimeout(() => {

    updateSlider(false);

  }, 100);

});
</script>


{% schema %}
{
  "name": "Final Premium Slider",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "PREMIUM"
    }
  ],

  "blocks": [
    {
      "type": "slide",
      "name": "Slide",

      "settings": [
        {
          "type": "video",
          "id": "video_url",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Main Image"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Thumbnail"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Name"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Price"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Final Premium Slider"
    }
  ]
}
{% endschema %}